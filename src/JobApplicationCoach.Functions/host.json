{
  "version": "2.0",
  "telemetryMode": "OpenTelemetry",
  "logging": {
    "logLevel": {
      "default": "Information",
      "Host.Results": "Error",
      "Host.Aggregator": "Warning",
      "Azure": "Warning",
      "Azure.Core": "Warning"
    }
  },
  "durableTask": {
    "hubName": "JobApplicationCoachHub",
    "storageProvider": {
      "type": "azure_storage"
    }
  },
  "extensions": {
    "http": {
      "routePrefix": "api"
    }
  }
}
